---
import Card from "./Card/index.astro";
import { LINKS } from "../lib/constants";
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-4">
  <div class="h-full">
    <header class="flex items-center">
      <h1 class="text-text text-xl font-bold">
        Let's start working together!
      </h1>
    </header>
    <address class="flex flex-col mt-4">
      <h2 class="text-text-secondary">Contact Details</h2>
      <p class="text-text">fr0ziisc2@gmail.com</p>
      <p class="text-text">Canary Islands, Spain</p>
    </address>
    <div class="flex flex-col mt-4 w-fit">
      <h2 class="text-text-secondary">Socials</h2>
      <ul class="text-text">
        <li>
          <a href={LINKS.linkedin} target="_blank">Linkedin</a>
        </li>
        <li>
          <a href={LINKS.github} target="_blank">Github</a>
        </li>
      </ul>
    </div>
  </div>
</Card>
